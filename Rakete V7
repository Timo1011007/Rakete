    Serial.println(lastEvent);
    logData("STATUS,SERVO," + String(millis() / 1000.0) + "," + lastEvent);
    lastStatusServo = currentServo;
  }

  // --- WiFi ---
  bool currentWiFi = (WiFi.getMode() == WIFI_AP || WiFi.getMode() == WIFI_AP_STA) && WiFi.softAPIP() != IPAddress(0,0,0,0);
  if (currentWiFi != lastStatusWiFi) {
