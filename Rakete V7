  servo.attach(SERVO_PIN, 500, 2500);
  servo.write(0);

  // --- BMP280 ---
  Serial.println("Starte BMP280-Test...");
  Wire.begin(4, 5);
  if (!bmp.begin(0x76)) {
    Serial.println("⚠️ Kein BMP280 gefunden!");
    lastEvent = "⚠️ BMP280 nicht gefunden!";
    sensor_ok = false;
    statusBMP = false;
  } else {
    Serial.println("✅ BMP280 erkannt!");
    lastEvent = "✅ BMP280 erkannt!";
    sensor_ok = true;
    statusBMP = true;
    const int nSamples = 30;
    float sum = 0;
    for (int i = 0; i < nSamples; i++) {
      sum += bmp.readAltitude(1013.25);
      delay(100);
    }
    startAltitude = sum / nSamples;
    millisStart = millis();
    Serial.print("🏁 Start-Höhe: ");
    Serial.println(startAltitude);
  }

  // --- SD-Karte ---
  SPI.begin(SD_SCK, SD_MISO, SD_MOSI, SD_CS);
  sd_ok = checkSDStatus(); // initial prüfen
  // Ensure current flight file exists if SD present
  if (sd_ok) {
    if (!SD.exists(currentFlightFile)) {
      File f = SD.open(currentFlightFile, FILE_WRITE);
      if (f) f.close();
    }
  }

  // --- Preferences ---
  preferences.begin("rocket", false);
  fallTolerance = preferences.getFloat("fallTol", 2.0);
  Serial.print("🌡️ Geladene Fallhöhe: ");
  Serial.println(fallTolerance);

  // --- WiFi ---
  bool apStarted = ensureAccessPoint(true);
  if (!apStarted) {
    lastEvent = "❌ WLAN AP Start fehlgeschlagen!";
    Serial.println(lastEvent);
  }

  // --- Server ---
  server.on("/", []() { server.send(200, "text/html", getPage()); });

  server.on("/data", []() {
    bool sdSaving = sd_ok && sdLoggingEnabled;
    String json = "{\"alt\":" + String(smoothedAltitude) +
                  ",\"max\":" + String(maxAltitudeSend) +
                  ",\"temp\":" + String(currentTemperature) +
                  ",\"t\":" + String(millis() - millisStart) +
                  ",\"parachute\":" + String(parachuteDeployed ? "true" : "false") +
                  ",\"event\":\"" + escapeJson(lastEvent) + "\"" +
                  ",\"statusBMP\":" + String(statusBMP ? "true" : "false") +
                  ",\"statusServo\":true" +
                  ",\"statusWiFi\":" + String(statusWiFi ? "true" : "false") +
                  ",\"statusSD\":" + String(sd_ok ? "true" : "false") +
                  ",\"sdSaving\":" + String(sdSaving ? "true" : "false") +
                  "}";
    server.send(200, "application/json", json);
    lastEvent = "";
  });

  server.on("/deploy", []() {
    servo.write(180);
    parachuteDeployed = true;
    deployTime = millis();
    lastEvent = "🪂 Fallschirm manuell ausgelöst!";
    Serial.println(lastEvent);
    logData("DEPLOY,," + String(millis() / 1000.0) + ",Fallschirm manuell ausgelöst");
    server.send(200, "text/plain", "Fallschirm manuell ausgelöst!");
  });

  server.on("/reset", []() {
    resetAll();
    parachuteDeployed = false;
    servo.write(0);
    server.send(200, "text/plain", "Alles zurückgesetzt!");
  });

  server.on("/setFall", []() {
    if (server.hasArg("value")) {
      fallTolerance = server.arg("value").toFloat();
      preferences.putFloat("fallTol", fallTolerance);
      lastEvent = "💾 Fallhöhe gespeichert: " + String(fallTolerance);
      Serial.println(lastEvent);
      logData("SET_FALL,," + String(millis() / 1000.0) + ",Fallhöhe gespeichert");
      server.send(200, "text/plain", "Fallhöhe gespeichert!");
    }
  });

  server.on("/setGround", []() {
    setGroundLevel();
    server.send(200, "text/plain", "Ground-Level neu gesetzt!");
  });

  server.on("/newFlight", []() {
    flightNumber++;
    currentFlightFile = "/flight" + String(flightNumber) + ".csv";
    maxAltitudeSend = 0;
    maxAltitude = -1000;
    historyIndex = 0;
    historyFull = false;
    movingIndex = 0;
    movingFull = false;
    for(int i=0;i<filterSize;i++) altitudeHistory[i]=0;
    for(int i=0;i<movingAverageSize;i++) movingBuffer[i]=0;
    lastEvent = "✈️ Neuer Flug gestartet: Flug " + String(flightNumber);
    Serial.println(lastEvent);
    logData("NEW_FLIGHT,," + String(millis()/1000.0) + ",Neuer Flug gestartet");
    // create file on SD if available
    if (sd_ok) {
      if (!SD.exists(currentFlightFile)) {
        File f = SD.open(currentFlightFile, FILE_WRITE);
        if (f) f.close();
      }
    }
    server.send(200, "text/plain", "Neuer Flug gestartet!");
  });

  server.on("/toggleSD", [](){
    sdLoggingEnabled = !sdLoggingEnabled;
    lastEvent = sdLoggingEnabled ? "💾 SD-Logging aktiviert" : "❌ SD-Logging deaktiviert";
    Serial.println(lastEvent);
    logData("TOGGLE_SD,," + String(millis() / 1000.0) + "," + lastEvent);
    server.send(200, "text/plain", lastEvent);
  });

