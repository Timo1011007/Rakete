  // 🔹 Diagramm-Daten
  String chartLabels = "";
  String chartData   = "";

  while (file.available()) {
    String line = file.readStringUntil('\n');
    line.trim();
    if (line.length() == 0) continue;

    int c1 = line.indexOf(',');
    int c2 = line.indexOf(',', c1 + 1);
    int c3 = line.indexOf(',', c2 + 1);

    String col1 = c1 >= 0 ? line.substring(0, c1) : "";
    String col2 = (c1 >= 0 && c2 > c1) ? line.substring(c1 + 1, c2) : "";
    String col3 = (c2 >= 0 && c3 > c2) ? line.substring(c2 + 1, c3) : "";
    String col4 = (c3 >= 0) ? line.substring(c3 + 1) : "";

    // Tabelle
    html += "<tr><td>" + col1 + "</td><td>" + col2 + "</td><td>" + col3 + "</td><td>" + col4 + "</td></tr>";

    // 🔹 Nur Höhenwerte ins Diagramm
