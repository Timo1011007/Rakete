// --- SD-Status prüfen (dynamisch) ---
bool checkSDStatus() {
  if (sd_ok) {
    File root = SD.open("/");
    if (!root) {
      sd_ok = false;
      lastEvent = "❌ SD-Karte entfernt!";
      Serial.println(lastEvent);
      logData("STATUS,SD," + String(millis() / 1000.0) + ",SD-Karte entfernt");
    } else {
      root.close();
    }
  } else {
    if (SD.begin(SD_CS)) {
      sd_ok = true;
      lastEvent = "💾 SD-Karte wieder erkannt!";
      Serial.println(lastEvent);
      logData("STATUS,SD," + String(millis() / 1000.0) + ",SD-Karte erkannt");
      // ensure flight file exists
      if (!SD.exists(currentFlightFile)) {
        File f = SD.open(currentFlightFile, FILE_WRITE);
        if(f) f.close();
      }
    }
  }
  return sd_ok;
}

// --- Funktionen ---
bool isStrictlyIncreasing() {
  if (!historyFull) return false;
  for (int i = 1; i < filterSize; i++) {
    if (altitudeHistory[i] + riseTolerance < altitudeHistory[i - 1]) return false;
  }
  return true;
}

float getSmoothedAltitude(float newVal) {
  movingBuffer[movingIndex] = newVal;
  movingIndex = (movingIndex + 1) % movingAverageSize;
  if (movingIndex == 0) movingFull = true;
  int n = movingFull ? movingAverageSize : movingIndex;
  if (n == 0) return newVal;
  float sum = 0;
  for (int i = 0; i < n; i++) sum += movingBuffer[i];
  return sum / n;
}


String escapeJson(const String &input) {
  String out = "";
  out.reserve(input.length() + 8);
  for (size_t i = 0; i < input.length(); i++) {
    char c = input[i];
    if (c == '\\') out += "\\\\";
    else if (c == '"') out += "\\\"";
    else if (c == '\n') out += "\\n";
    else if (c == '\r') out += "\\r";
    else if (c == '\t') out += "\\t";
    else out += c;
  }
  return out;
}

