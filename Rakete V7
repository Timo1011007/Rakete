bool ensureAccessPoint(bool forceRestart = false) {
  bool apRunning = (WiFi.getMode() == WIFI_AP || WiFi.getMode() == WIFI_AP_STA) && WiFi.softAPIP() != IPAddress(0,0,0,0);

  if (!forceRestart && apRunning) {
    statusWiFi = true;
    return true;
  }

  WiFi.persistent(false);
  WiFi.disconnect(true, true);
  WiFi.softAPdisconnect(true);
  WiFi.mode(WIFI_MODE_NULL);
  delay(100);

  WiFi.mode(WIFI_AP);
  WiFi.setSleep(false);
  WiFi.softAPConfig(ap_ip, ap_gateway, ap_subnet);
  delay(100);
  WiFi.mode(WIFI_AP);
  WiFi.setSleep(false);

  bool apStarted = WiFi.softAP(ap_ssid, ap_password, ap_channel, false, ap_max_clients);
  if (apStarted) {
    IPAddress ip = WiFi.softAPIP();
    statusWiFi = true;
    Serial.print("📡 WLAN/AP aktiv. IP: ");
    Serial.println(ip);
    logData("STATUS,WIFI," + String(millis() / 1000.0) + ",AP aktiv: " + ip.toString());
  } else {
    statusWiFi = false;
    Serial.println("❌ WLAN/AP Start fehlgeschlagen!");
    logData("STATUS,WIFI," + String(millis() / 1000.0) + ",AP Start fehlgeschlagen");
  }

  return apStarted;
}

