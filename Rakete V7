// LOOP
// ==============================
void loop() {
  server.handleClient();

  static unsigned long lastStatusCheck = 0;
  if (millis() - lastStatusCheck >= 1000) {
    lastStatusCheck = millis();
    checkComponentStatus();
  }

  bool apRunning = (WiFi.getMode() == WIFI_AP || WiFi.getMode() == WIFI_AP_STA) && WiFi.softAPIP() != IPAddress(0,0,0,0);
  if (!apRunning && (millis() - lastWiFiRetry >= wifiRetryInterval)) {
    lastWiFiRetry = millis();
    lastEvent = "⚠️ WLAN getrennt, AP wird neu gestartet...";
    Serial.println(lastEvent);
    ensureAccessPoint(true);
  }

  // LED blinkt bei OK
  if (sensor_ok && statusWiFi) {
    if (millis() - lastBlink >= blinkInterval) {
      lastBlink = millis();
      ledState = !ledState;
      digitalWrite(LED_PIN, ledState ? HIGH : LOW);
    }
  } else {
    digitalWrite(LED_PIN, LOW);
  }

  if (!sensor_ok) return;

  currentAltitude = bmp.readAltitude(1013.25);
  currentTemperature = bmp.readTemperature();
  displayAltitude = currentAltitude - startAltitude - groundOffset;
  smoothedAltitude = getSmoothedAltitude(displayAltitude);

  Serial.print("Höhe roh: ");
  Serial.print(currentAltitude);
  Serial.print(" m | geglättet: ");
  Serial.print(smoothedAltitude);
  Serial.print(" | Temp: ");
  Serial.print(currentTemperature);
  Serial.println(" C");
  Serial.println(smoothedAltitude);
  if (smoothedAltitude > maxAltitudeSend) maxAltitudeSend = smoothedAltitude;

  altitudeHistory[historyIndex] = displayAltitude;
  historyIndex = (historyIndex + 1) % filterSize;
  if (historyIndex == 0) historyFull = true;

  // SD-Logging
  logData("DATA," + String(smoothedAltitude, 2) + "," + String(millis() / 1000.0) + ",");

  // Fallschirm-Logik
  if (!parachuteDeployed) {
    if (isStrictlyIncreasing() && displayAltitude > maxAltitude) {
      maxAltitude = displayAltitude;
    } else if (maxAltitude - displayAltitude >= fallTolerance) {
      servo.write(180);
      parachuteDeployed = true;
      deployTime = millis();
      lastEvent = "🪂 Fallschirm automatisch ausgelöst!";
      Serial.println(lastEvent);
      logData("DEPLOY_AUTO,," + String(millis() / 1000.0) + ",Fallschirm automatisch ausgelöst");
    }
  } else {
    if (millis() - deployTime >= zurueck) {
      servo.write(0);
      parachuteDeployed = false;
      maxAltitude = -1000;
    }
  }

  delay(100);
}
